# Hosted Supabase dev project. Create one at https://supabase.com/dashboard/new
# (name it evalmvp-dev, free tier). All values below are filled from
# Settings → API and Settings → Database in the dashboard.

NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Transaction-mode pooler (port 6543). Username is `postgres.<project-ref>`.
# Direct connection at db.<ref>.supabase.co:5432 is IPv6-only on newer projects and
# fails on most dev networks. Use the pooler — it's what production uses anyway.
# Drizzle clients have `prepare: false` set, required for transaction-mode pooler.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL_SERVICE=postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:6543/postgres

# OAuth token encryption (AES-256-GCM, 32 bytes hex). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
OAUTH_TOKEN_KEY=

# Inngest (local dev; cloud values for production)
INNGEST_EVENT_KEY=local
INNGEST_SIGNING_KEY=local

# Project reference (for CLI commands)
SUPABASE_PROJECT_REF=<project-ref>
